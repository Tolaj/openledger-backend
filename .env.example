# ===========================
# SERVER CONFIG
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# MONGO DATABASE
# ===========================
MONGO_URI=mongodb://localhost:27017/
DB_NAME=openledger

# ===========================
# AUTH
# ===========================
JWT_SECRET=change-me-in-production


# ===========================
# ENCRYPTION (AES-256-GCM — used to encrypt stored SMTP passwords)
# ===========================
ENCRYPTION_KEY=76e2e84260d029b05e8e03eb1e7d1ac115262ac30c071a1662114c396851b51d

# ===========================
# GEMINI AI (free tier — get key at aistudio.google.com)
# ===========================
GEMINI_API_KEY=your-gemini-api-key-here

# ===========================
# EMAIL / SMTP CONFIG
# ===========================
# For Gmail: enable 2FA, generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER= email@example.com
SMTP_PASS= app password

