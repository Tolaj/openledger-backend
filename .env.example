# ===========================
# SERVER CONFIG
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# MONGO DATABASE
# ===========================
MONGO_URI=your_mongo_connection_string_here
DB_NAME=testDB

# ===========================
# SESSION
# ===========================
SESSION_SECRET=change-me-in-production
SESSION_NAME=AppSession
AFTER_LOGIN_REDIRECT=/

# ===========================
# EMAIL / GMAIL OAUTH CONFIG
# ===========================
GMAIL_ID=your_gmail_address_here
EMAIL_CLIENT_ID=your_google_oauth_client_id_here
EMAIL_CLIENT_SECRET=your_google_oauth_client_secret_here
EMAIL_REFRESH_TOKEN=your_google_oauth_refresh_token_here
